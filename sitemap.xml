---
excludeFromSitemap: true
---
{% assign siteURL = site.data.global.url %}
{%- capture compressedXml -%}
  <?xml version="1.0" encoding="UTF-8"?>
  <urlset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9 http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd" xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% comment %}
    {% for post in site.posts %}
      {% unless post.published == false %}
      <url>
        <loc>{{ siteURL }}{{ post.url }}</loc>
        {% if post.sitemap.lastmod %}
          <lastmod>{{ post.sitemap.lastmod | date: "%Y-%m-%d" }}</lastmod>
        {% elsif post.date %}
          <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
        {% else %}
          <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        {% endif %}
        {% if post.sitemap.changefreq %}
          <changefreq>{{ post.sitemap.changefreq }}</changefreq>
        {% else %}
          <changefreq>monthly</changefreq>
        {% endif %}
        {% if post.sitemap.priority %}
          <priority>{{ post.sitemap.priority }}</priority>
        {% else %}
          <priority>0.5</priority>
        {% endif %}
      </url>
      {% endunless %}
    {% endfor %}
  {% endcomment %}
    <url>
      <loc>{{ siteURL }}/</loc>
    </url>
    {% for page in site.pages %}
      {% assign redirect = false %}
      {% assign urlSize = page.url | size %}
      {% assign adjustedUrlSize = urlSize | minus: 1 %}
      {% assign lastChar = page.url | slice: adjustedUrlSize %}
      {% unless page.excludeFromSitemap == true or page.name == "redirects.json" or page.url contains ".css" or page.url contains ".js" or page.url contains ".txt" or page.url contains ".webmanifest" or page.url contains ".json" or lastChar == "/" %}
      <url>
        <loc>{{ siteURL }}{{ page.url | remove: ".html" }}</loc>
      </url>
      {% endunless %}
    {% endfor %}
  </urlset>
{%- endcapture -%}{{ compressedXml | remove: "  " | remove: "	" | strip_newlines }}
