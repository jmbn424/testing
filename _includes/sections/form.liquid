{% comment %}

This is an improved version of AgencyBloc's lead form tool HTML output. See original vendor code for reference:
https://github.com/jmbn424/website-documentation/blob/main/technical/lead-form-code.md

{% endcomment %}
{% assign contactForm = site.data.global.contactForm %}
<section class="bg-light-gray">
    <div class="max-width-mobile-landscape">
        <h2 class="t-align-center">Get in touch</h2>
        <form class="form" action="https://app.agencybloc.com/fp/webToLead/v1/BBZXH5SZLV4KWOOSRUGT/" method="post">
            <div class="form__field">
                <label for="field-first-name">First Name</label>
                <input id="field-first-name" name="firstName" type="text" autocomplete="given-name" maxlength="64" required size="40" value="">
            </div>
            <div class="form__field">
                <label for="field-last-name">Last Name</label>
                <input id="field-last-name" name="lastName" type="text" autocomplete="family-name" maxlength="64" required size="40" value="">
            </div>
            <div class="form__field">
                <label for="field-phone">Phone Number</label>
                <input id="field-phone" name="cellPhone" type="tel" autocomplete="tel" pattern="\+?1?[ .\-]?\(?\d{3}\)?[ .\-]?\d{3}[ .\-]?\d{4}" minlength="10" maxlength="20" required size="40" value="">
            </div>
            <div class="form__field">
                <label for="field-email">Email Address <span class="text-secondary">(optional)</span></label>
                <input id="field-email" name="email" type="email" autocomplete="email" maxlength="254" size="40" value="">
            </div>
            <div class="form__field is-visually-hidden" aria-hidden="true">
                <label for="field-website">Home Page URL <span class="text-secondary">(optional)</span></label>
                <input id="field-website" name="_Website" type="text" tabindex="-1" autocomplete="new-password" data-1p-ignore data-lpignore="true" placeholder="https://example.com" size="40" value="">
            </div>
            <div class="form__field">
                <label for="field-message">Message <span class="text-secondary">(optional)</span></label>
                <textarea id="field-message" name="custom_Message" maxlength="800" cols="40" rows="5"></textarea>
            </div>
            <fieldset class="form__consent">
                <legend class="is-visually-hidden">Consent</legend>
                <p>
                    <small>{{ contactForm.consentIntro }}</small>
                </p>
                <p class="form__field--checkbox">
                    <input type="checkbox" name="custom_Terms Consent" value="1" required aria-labelledby="terms-consent-text">
                    <span id="terms-consent-text">{{ contactForm.termsConsent }}</span>
                </p>
                {% if site.data.global.SMSProgramIsLive == true %}
                    <p class="form__field--checkbox">
                        <input type="checkbox" name="custom_SMS Consent" value="1" aria-labelledby="sms-consent-text">
                        <span id="sms-consent-text">{{ contactForm.smsConsent }}</span>
                    </p>
                {% endif %}
            </fieldset>
            <p><small>{{ contactForm.solicitation }}</small></p>
            <div class="form__submit form-action">
                <button type="submit">Submit</button>
            </div>
        </form>
    </div>
</section>
