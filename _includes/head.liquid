{% assign siteData = site.data.global %}{%- comment -%}Active jurisdiction codes in canonical display order, from the jurisdictions switchboard map; feeds JSON-LD areaServed (the prose token uses _includes/licensed-states.liquid off the same source).{%- endcomment -%}{%- assign activeStates = '' -%}{%- for j in siteData.jurisdictions -%}{%- if j[1] -%}{%- assign activeStates = activeStates | append: j[0] | append: ',' -%}{%- endif -%}{%- endfor -%}{% assign activeStates = activeStates | split: ',' %}
<head>
    <!-- Document -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="format-detection" content="telephone=no">

    <!-- SEO -->
    {% assign pageTitle = siteData.defaultPageTitle %}
    {% assign pageDescription = siteData.defaultPageDescription %}
    {% if page.title %}
        {% assign pageTitle = page.title %}
    {% endif %}
    {% if page.description %}
        {% assign pageDescription = page.description %}
    {% endif %}
    <title>{{ pageTitle | replace: "&", "&amp;" }}</title>
    <meta name="description" content="{{ pageDescription | replace: "&", "&amp;" }}">
    {% comment %} Deploy-exposure gates: the global switches in _data/global.yml, each AND-ed with the per-page excludeFromSitemap opt-out. siteIsIndexable=false (e.g. the testing deploy) emits a site-wide noindex and drops the canonical; showStructuredData / includeSocialShareMeta gate the JSON-LD and the og/twitter block independently, so a non-indexable deploy can still emit testable cards + structured data. {% endcomment %}
    {% assign showCanonical = false %}{% if siteData.siteIsIndexable and page.excludeFromSitemap != true %}{% assign showCanonical = true %}{% endif %}
    {% assign showSchema = false %}{% if siteData.showStructuredData and page.excludeFromSitemap != true %}{% assign showSchema = true %}{% endif %}
    {% assign showSocial = false %}{% if siteData.includeSocialShareMeta and page.excludeFromSitemap != true %}{% assign showSocial = true %}{% endif %}
    {% unless siteData.siteIsIndexable %}<meta name="robots" content="noindex, nofollow">{% endunless %}
    {% comment %} Canonical absolute URL from the single source of truth (site.data.global.url, which carries the trailing slash): home -> base URL, sub-pages -> base + extensionless path. {% endcomment %}
    {% assign canonicalUrl = page.url | remove_first: "/" | replace: "index.html", "" | replace: ".html", "" | prepend: siteData.url %}
    {% if showCanonical %}
        <link rel="canonical" href="{{ canonicalUrl }}">
    {% endif %}

    <!-- Appearance -->
    <meta name="theme-color" content="#ffffff">
    <link rel="preload" as="font" type="font/woff2" crossorigin href="{{ siteData.basePath }}assets/fonts/inter-variable.woff2">
    <link rel="stylesheet" href="{{ siteData.basePath }}assets/css/main.css">

    <!-- Icons -->
    <link rel="icon" href="{{ siteData.basePath }}favicon.ico" sizes="any">
    <link rel="apple-touch-icon" sizes="180x180" href="{{ siteData.basePath }}assets/images/ui/apple-touch-icon.png">
    <link rel="manifest" href="{{ siteData.basePath }}manifest.webmanifest">

    {% if showSocial %}
        <!-- Sharing -->
        <meta property="og:type" content="website">
        <meta property="og:title" content="{{ pageTitle }}">
        <meta property="og:description" content="{{ pageDescription }}">
        <meta property="og:image" content="{{ siteData.url }}assets/images/ui/social.png">
        <meta property="og:image:alt" content="J&amp;R Health Insurance">
        <meta property="og:image:type" content="image/png">
        <meta property="og:image:width" content="1200">
        <meta property="og:image:height" content="630">
        <meta property="og:url" content="{{ canonicalUrl }}">
        <meta property="og:site_name" content="J&amp;R Health Insurance">
        <meta property="og:locale" content="en_US">
        <meta name="twitter:card" content="summary_large_image">
    {% endif %}

    {% if showSchema %}
        <!-- Structured Data -->
        <script type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@graph": [
                    {
                        "@type": "WebSite",
                        "@id": "{{ siteData.url }}#website",
                        "url": "{{ siteData.url }}",
                        "name": "J&R Health Insurance",
                        "publisher": { "@id": "{{ siteData.url }}#organization" },
                        "inLanguage": "en-US"
                    },
                    {
                        "@type": "{{ page.schemaType | default: 'WebPage' }}",
                        "@id": "{{ canonicalUrl }}#webpage",
                        "url": "{{ canonicalUrl }}",
                        "name": {{ pageTitle | jsonify }},
                        "description": {{ pageDescription | jsonify }},
                        "isPartOf": { "@id": "{{ siteData.url }}#website" },
                        "about": { "@id": "{{ siteData.url }}#organization" },{% if page.lastUpdated %}
                        "dateModified": "{{ page.lastUpdated | date_to_xmlschema }}",{% endif %}
                        "inLanguage": "en-US"
                    },
                    {
                        "@type": "InsuranceAgency",
                        "@id": "{{ siteData.url }}#organization",
                        "name": "J&R Health Insurance",
                        "url": "{{ siteData.url }}",
                        "logo": {
                            "@type": "ImageObject",
                            "url": "{{ siteData.url }}assets/images/ui/icon-512.png",
                            "width": 512,
                            "height": 512,
                            "caption": "J&R Health Insurance"
                        },
                        "image": "{{ siteData.url }}assets/images/ui/social.png",
                        "telephone": "+12535288805",
                        "faxNumber": "+12533638808",
                        "email": "info@jrhealthins.org",
                        "address": {
                            "@type": "PostalAddress",
                            "streetAddress": "702 S Hill Park Dr, Ste 205",
                            "addressLocality": "Puyallup",
                            "addressRegion": "WA",
                            "postalCode": "98373",
                            "addressCountry": "US"
                        },
                        "geo": {
                            "@type": "GeoCoordinates",
                            "latitude": 47.1606086,
                            "longitude": -122.3020523
                        },
                        "openingHoursSpecification": [{
                            "@type": "OpeningHoursSpecification",
                            "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
                            "opens": "09:30",
                            "closes": "17:30"
                        }],
                        "areaServed": [{% for abbr in activeStates %}{% assign st = site.data.reference.states[abbr] %}
                            { "@type": "State", "name": "{{ st.name }}", "sameAs": "{{ st.wikidata }}" }{% unless forloop.last %},{% endunless %}{% endfor %}
                        ],
                        "hasOfferCatalog": {
                            "@type": "OfferCatalog",
                            "name": "Insurance brokerage services",
                            "itemListElement": [{
                                "@type": "Offer",
                                "itemOffered": {
                                    "@type": "Service",
                                    "name": "Medicare guidance for first-time eligibles"
                                }
                            }, {
                                "@type": "Offer",
                                "itemOffered": {
                                    "@type": "Service",
                                    "name": "ACA Marketplace guidance"
                                }
                            }, {
                                "@type": "Offer",
                                "itemOffered": {
                                    "@type": "Service",
                                    "name": "Medicare guidance for veterans and their families"
                                }
                            }]
                        },
                        "hasMap": "https://maps.google.com/maps?cid=9426287045452652682",
                        "sameAs": [{% for handle in siteData.publishedSocialProfiles %}{% assign profile = siteData.socialProfiles | where: "id", handle | first %}
                            "{{ profile.url }}"{% unless forloop.last %},{% endunless %}{% endfor %}
                        ]
                    }
                ]
            }
        </script>
    {% endif %}
</head>
